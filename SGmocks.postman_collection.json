{
  "info": {
    "name": "SGmocks API",
    "description": "Collection for testing SGmocks mock banking API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Check if the API is running"
      },
      "response": []
    },
    {
      "name": "BANCO",
      "item": [
        {
          "name": "Transferencia",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cuit\": \"20123456789\",\n  \"cuenta\": \"1234567890\",\n  \"monto\": 1000.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/banco/Transferencia",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "banco",
                "Transferencia"
              ]
            },
            "description": "Create a new transfer transaction"
          },
          "response": []
        },
        {
          "name": "Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"client_credentials\",\n  \"client_id\": \"your_client_id\",\n  \"client_secret\": \"your_client_secret\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/banco/token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "banco",
                "token"
              ]
            },
            "description": "Request an access token"
          },
          "response": []
        },
        {
          "name": "MovimientoFondos",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idDebitoPropios\": \"123456\",\n  \"idCreditoPropios\": \"654321\",\n  \"monto\": 500.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/banco/Transferencia/MovimientoFondos",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "banco",
                "Transferencia",
                "MovimientoFondos"
              ]
            },
            "description": "Record movement of funds between accounts"
          },
          "response": []
        },
        {
          "name": "TransferenciaInterna",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cuentaOrigen\": \"1234567890\",\n  \"cuentaDestino\": \"0987654321\",\n  \"monto\": 250.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/banco/TransferenciaInterna",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "banco",
                "TransferenciaInterna"
              ]
            },
            "description": "Perform an internal transfer between accounts"
          },
          "response": []
        },
        {
          "name": "TransferenciaCoinag",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cuit\": \"20123456789\",\n  \"cvu\": \"1234567890123456789012\",\n  \"monto\": 1500.00,\n  \"concepto\": \"Transferencia Coinag\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/banco/TransferenciaCoinag",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "banco",
                "TransferenciaCoinag"
              ]
            },
            "description": "Perform a transfer via Coinag service"
          },
          "response": []
        }
      ]
    },
    {
      "name": "INTEGRADOR",
      "item": [
        {
          "name": "Transacciones",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idTransaccion\": \"TRX001\",\n  \"monto\": 1000.00,\n  \"tipo\": \"transferencia\",\n  \"estados\": \"pendiente\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/integrador/Transacciones",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "integrador",
                "Transacciones"
              ]
            },
            "description": "Register a transaction with the integrator"
          },
          "response": []
        },
        {
          "name": "NovedadCVU",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cuit\": \"20123456789\",\n  \"cvu\": \"1234567890123456789012\",\n  \"estado\": \"activo\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/integrador/Cuentas/NovedadCVU",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "integrador",
                "Cuentas",
                "NovedadCVU"
              ]
            },
            "description": "Register an account novelty/update in the system"
          },
          "response": []
        },
        {
          "name": "Saldo",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/integrador/Saldo/20123456789/1234567890",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "integrador",
                "Saldo",
                "20123456789",
                "1234567890"
              ]
            },
            "description": "Get account balance by CUIT and account number"
          },
          "response": []
        }
      ]
    },
    {
      "name": "ADMIN",
      "item": [
        {
          "name": "Config",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"GAP\": 3,\n  \"ID_TRX\": 15000,\n  \"IS_ERROR\": true,\n  \"RANDOM_STR_LENGTH\": 15,\n  \"STATUS_BANCO_TRANSFERENCIA\": 400,\n  \"STATUS_BANCO_TOKEN\": 500\n}"
            },
            "url": {
              "raw": "{{base_url}}/admin/config",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "admin",
                "config"
              ]
            },
            "description": "Update configuration variables at runtime. Supported fields: GAP, ID_TRX, IS_ERROR, RANDOM_STR_LENGTH, RANDOM_STR_ERROR_LENGTH, and all STATUS_* variables for each endpoint."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:{{port}}",
      "type": "string"
    },
    {
      "key": "port",
      "value": "5888",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    }
  ]
}
